# Copy this file to .env locally if you use a shell helper that loads env files.
# Do not commit real tokens.

# Example: https://gitlab.com/api/v4/projects/123456/ml/mlflow
MLFLOW_TRACKING_URI=https://<gitlab-host>/api/v4/projects/<project-id>/ml/mlflow

# GitLab personal/project/group access token with api scope and Developer or higher role.
MLFLOW_TRACKING_TOKEN=<gitlab-access-token>

# Optional. Forces GitLab-compatible artifact logging if your endpoint is proxied or non-standard.
GITLAB_MLFLOW=1

# Optional. Used when registering a model version; must be semantic versioning.
GITLAB_MODEL_VERSION=0.1.0
